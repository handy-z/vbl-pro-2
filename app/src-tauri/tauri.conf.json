{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VBL Pro 2",
  "version": "0.1.0",
  "identifier": "com.vbl.pro2",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "bun run --cwd ../ui dev",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VBL Pro 2",
        "width": 860,
        "height": 720,
        "minWidth": 540,
        "minHeight": 540,
        "backgroundColor": "#0f1216",
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": ["icons/icon.ico"],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/handy-z/vbl-pro-2/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZDODQyNjNFNEU2MTRFMTAKUldRUVRtRk9QaWFFL0pIMUhqVGtac0c5dCtSUnZGR0xwVFZlSEVVYWh0d0svTjlNMWNjZDlDR24K"
    }
  }
}
